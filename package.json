{
  "name": "easepaste",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "nodemon --watch src --ext ts --exec ts-node src/api/index.ts",
    "dev:worker": "nodemon --watch src --ext ts --exec ts-node src/worker/index.ts",
    "build": "tsc",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate:up": "ts-node migrations/runner.ts up",
    "migrate:down": "ts-node migrations/runner.ts down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.575.0",
    "@aws-sdk/s3-request-presigner": "^3.575.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.7.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.5.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
