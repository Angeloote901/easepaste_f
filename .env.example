# ===========================================================
# EasePaste Environment Variables
# Copy this file to .env and fill in the values
# ===========================================================

# Application
NODE_ENV=development
PORT=3000

# PostgreSQL Database
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://easepaste:easepaste@localhost:5432/easepaste

# Redis
# Format: redis://host:port  or  redis://:password@host:port
REDIS_URL=redis://localhost:6379

# JWT Secrets — must be at least 32 characters each
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-string-32-chars

# JWT Expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# MinIO / S3 Object Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=easepaste-documents
# Set to true when using MinIO or any S3-compatible service with path-style URLs
S3_FORCE_PATH_STYLE=true

# Logging
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Brute Force Protection
# Maximum login attempts before account is temporarily locked
BF_MAX_ATTEMPTS=10
# Lock window in seconds (900 = 15 minutes)
BF_WINDOW_SECONDS=900
